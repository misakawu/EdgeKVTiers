e.Play();\n            }\n            else if (!isPlaying && audioSource.isPlaying)\n            {\n                audioSource.Stop();\n            }\n        }\n    }\n}\n```\nThis script assumes that you have already set up Photon PUN 2 in your Unity project and have an active connection to the network.\n\nNow, to create a subclass of AudioSource that is networked, you can use the following example script:\n```c#\nusing UnityEngine;\nusing Photon.Pun;\n\npublic class NetworkedAudioSource : MonoBehaviourPun, IPunObservable\n{\n    private AudioSource audioSource;\n\n    void Start()\n    {\n        audioSource = GetComponent<AudioSource>();\n    }\n\n    public void OnPhotonSerializeView(PhotonStream stream, PhotonMessageInfo info)\n    {\n        if (stream.IsWriting)\n        {\n            stream.SendNext(audioSource.volume);\n            stream.SendNext(audioSource.pitch);\n            stream.SendNext(audioSource.loop);\n            stream.SendNext(audioSource.time);\n            stream.SendNext(audioSource.isPlaying);\n        }\n        else\n        {\n            audioSource.volume = (float)stream.ReceiveNext();\n            audioSource.pitch = (float)stream.ReceiveNext();\n            audioSource.loop = (bool)stream.ReceiveNext();\n\n            float time = (float)stream.ReceiveNext();\n            bool isPlaying = (bool)stream.ReceiveNext();\n\n            if (!audioSource.isPlaying)\n            {\n                audioSource.time = time;\n            }\n\n            if (isPlaying && !audioSource.isPlaying)\n            {\n                audioSource.Play();\n            }\n            else if (!isPlaying && audioSource.isPlaying)\n            {\n                audioSource.Stop();\n            }\n        }\n    }\n}\n```\nWith these two scripts, you should be able to network your XR Interactable and AudioSource components using Photon PUN 2.\nUser: Great job! now i need a networked physics character controller\nAssistant:", params: SamplingParams(n=1