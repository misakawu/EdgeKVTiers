# Runtime outputs and experiment artifacts
out/
data/
runtime/
**/out/
**/runtime/

# Large local assets that must not be uploaded
models/
third_party/

# Python caches
__pycache__/
*.py[cod]
*$py.class

# Virtual environments and local tool state
.venv/
venv/
env/
.env
.claude/
.pytest_cache/

# OS/editor noise
.DS_Store
.idea/
.vscode/

# New files are expected to be source/docs only unless explicitly staged.
*
!*/
!*.md
!*.py
!h1/run_h1_lpe_budget_quick.sh
!h1/run_h1_lpe_serving_bench.sh
!h1/run_h1_policy_serving_bench.sh
!h1/step1_D3/run_step1_D3_monitor.sh
!h0/configs/*.json
!env_locks/*.txt
!.gitignore

# Keep large downloaded assets ignored even though directories are generally visible.
models/**
third_party/**
